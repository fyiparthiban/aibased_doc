# Copy this file to .env and fill in your API key
GROQ_API_KEY=your_groq_api_key_here
BACKEND_PORT=8003
# Optional: set a Hugging Face token to access private models or avoid rate limits
# HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here
# Optional: override the Chroma DB location
# CHROMA_DB_DIR=milestone1/chroma_db
# Optional: override the Chroma collection name
# CHROMA_COLLECTION_NAME=milestone1_collection
# Optional: override the embedding model
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
